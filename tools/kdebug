#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
root="$(cd "$script_dir/.." && pwd)"
export KVERIF_HOME="${KVERIF_HOME:-$root}"

if [[ "$#" -eq 1 && ( "$1" == "-h" || "$1" == "-help" ) ]]; then
  cat "$root/kdebug/help.txt"
  exit 0
fi

if [[ -n "${VERDI_HOME:-}" ]]; then
  npi_lib="$VERDI_HOME/share/NPI/lib/LINUX64"
  if [[ ! -d "$npi_lib" ]]; then
    npi_lib="$VERDI_HOME/share/NPI/lib/linux64"
  fi
  if [[ -d "$npi_lib" ]]; then
    export LD_LIBRARY_PATH="$npi_lib:${LD_LIBRARY_PATH:-}"
  fi
fi

if [[ -x "$root/kdebug/kdebug" ]]; then
  exec "$root/kdebug/kdebug" "$@"
fi

tcl_engine="$root/kdebug/tcl_engine/kdebug-engine"
if [[ -x "$tcl_engine" ]]; then
  if [[ "$#" -eq 1 && "$1" == "-" ]]; then
    exec "$tcl_engine" ai query -
  fi
  if [[ "$#" -eq 2 && "$1" == "--json" && "$2" == "-" ]]; then
    exec "$tcl_engine" ai query -
  fi
fi

echo "ERROR: kdebug frontend binary is missing and Tcl fallback cannot handle these arguments: $*" >&2
exit 2
