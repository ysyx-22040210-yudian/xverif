#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
root="$(cd "$script_dir/.." && pwd)"

if [[ "$#" -eq 1 && ( "$1" == "-h" || "$1" == "-help" ) ]]; then
  cat "$root/xdebug/help.txt"
  exit 0
fi

if [[ -z "${VERDI_HOME:-}" ]]; then
  echo "ERROR: VERDI_HOME environment variable is not set" >&2
  exit 1
fi

npi_lib="$VERDI_HOME/share/NPI/lib/LINUX64"
if [[ ! -d "$npi_lib" ]]; then
  npi_lib="$VERDI_HOME/share/NPI/lib/linux64"
fi
if [[ ! -d "$npi_lib" ]]; then
  echo "ERROR: cannot find Verdi NPI library directory under VERDI_HOME=$VERDI_HOME" >&2
  exit 1
fi

export LD_LIBRARY_PATH="$npi_lib:${LD_LIBRARY_PATH:-}"
exec "$root/xdebug/xdebug" "$@"
