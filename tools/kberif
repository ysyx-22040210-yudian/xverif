#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
root="$(cd "$script_dir/.." && pwd)"

python_bin="${KBERIF_PYTHON:-}"
if [[ -z "$python_bin" ]]; then
  if [[ -x "${HOME}/miniconda3/envs/kberif-py311/bin/python" ]]; then
    python_bin="${HOME}/miniconda3/envs/kberif-py311/bin/python"
  elif [[ -x "${HOME}/miniconda3/bin/python" ]]; then
    python_bin="${HOME}/miniconda3/bin/python"
  else
    python_bin="${PYTHON:-python3}"
  fi
fi

export PYTHONPATH="$root/kberif${PYTHONPATH:+:${PYTHONPATH}}"
exec "$python_bin" -m kberif "$@"
