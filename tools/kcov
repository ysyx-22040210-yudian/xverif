#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
root="$(cd "$script_dir/.." && pwd)"

python_bin="${PYTHON:-${KVERIF_KCOV_PYTHON:-}}"
if [[ -z "$python_bin" ]]; then
  if [[ -x "${HOME}/miniconda3/envs/kverif-mcp/bin/python" ]]; then
    python_bin="${HOME}/miniconda3/envs/kverif-mcp/bin/python"
  elif command -v python3.11 >/dev/null 2>&1; then
    python_bin="python3.11"
  elif [[ -x "${VERDI_HOME:-}/platform/linux64/Python/bin/python" ]]; then
    python_bin="${VERDI_HOME}/platform/linux64/Python/bin/python"
  else
    python_bin="python3"
  fi
fi

export PYTHONPATH="$root/kcov${PYTHONPATH:+:${PYTHONPATH}}"
exec "$python_bin" -m kcov.cli "$@"
