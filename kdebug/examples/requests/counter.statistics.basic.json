{
  "api_version": "kdebug.v1",
  "action": "counter.statistics",
  "target": {
    "session_id": "wave0"
  },
  "args": {
    "clock": "top.clk",
    "sampling": "posedge",
    "time_range": {
      "begin": "100ns",
      "end": "200ns"
    },
    "vld": {
      "expr": "valid && ready",
      "signals": {
        "valid": "top.valid",
        "ready": "top.ready"
      }
    },
    "cnt": "{top.cnt_hi,top.cnt_lo}",
    "max_samples": 1000
  }
}
