#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$script_dir/tcl_engine/xdebug_engine.py" ]]; then
  engine_dir="$script_dir/tcl_engine"
else
  engine_dir="$(cd "$script_dir/../tcl_engine" && pwd)"
fi

python_bin="${PYTHON:-python3}"
exec "$python_bin" "$engine_dir/xdebug_engine.py" "$@"
